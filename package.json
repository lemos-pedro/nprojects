{
  "name": "ngola-projects",
  "version": "0.0.1",
  "private": true,
  "workspaces": [
    "apps/*",
    "libs/*"
  ],
  "_moduleAliases": {
    "@ngola/database": "dist/libs/database/src",
    "@ngola/shared": "dist/libs/shared/src"
  },
  "scripts": {
    "start": "nx serve api-gateway",
    "api-gateway": "nx serve api-gateway",
    "auth-service": "nx serve auth-service",
    "project-service": "nx serve project-service",
    "build:all": "nx run-many --target=build --all",
    "test:all": "nx run-many --target=test --all",
    "lint:all": "nx run-many --target=lint --all",
    "build:libs": "tsc -p tsconfig.libs.json && tsc-alias -p tsconfig.libs.json",
    "docker:up": "docker compose --env-file .env -f docker-compose.yml -f docker-compose.full.yml up -d --build",
    "docker:down": "docker compose -f docker-compose.yml -f docker-compose.full.yml down",
    "docker:logs": "docker compose -f docker-compose.yml -f docker-compose.full.yml logs -f",
    "docker:infra:up": "docker compose --env-file .env -f docker-compose.yml up -d",
    "docker:infra:down": "docker compose -f docker-compose.yml down",
    "format": "prettier --write ."
  },
  "dependencies": {
    "@nestjs/common": "^10.4.15",
    "@nestjs/core": "^10.4.15",
    "@nestjs/platform-express": "^10.4.15",
    "@nestjs/platform-socket.io": "^10.4.15",
    "@nestjs/websockets": "^10.4.15",
    "axios": "^1.8.4",
    "bcryptjs": "^3.0.2",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.0",
    "helmet": "^8.1.0",
    "livekit-server-sdk": "^2.15.0",
    "module-alias": "^2.2.3",
    "pg": "^8.13.3",
    "reflect-metadata": "^0.2.2",
    "resend": "^6.10.0",
    "rxjs": "^7.8.2",
    "socket.io": "^4.7.5",
    "stripe": "^16.12.0",
    "tsconfig-paths": "^4.2.0",
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "@commitlint/cli": "^18.0.0",
    "@commitlint/config-conventional": "^18.0.0",
    "@nestjs/testing": "^10.4.22",
    "@nx/eslint-plugin": "^17.0.0",
    "@nx/jest": "^17.0.0",
    "@nx/js": "^17.0.0",
    "@nx/nest": "^17.0.0",
    "@nx/node": "^17.0.0",
    "@types/jest": "^29.0.0",
    "@types/node": "^20.19.37",
    "@types/pg": "^8.18.0",
    "@types/supertest": "^6.0.3",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "babel-plugin-macros": "^3.1.0",
    "cosmiconfig": "^7.1.0",
    "eslint": "^8.57.0",
    "husky": "^9.0.0",
    "jest": "^29.0.0",
    "lint-staged": "^15.0.0",
    "nx": "^17.0.0",
    "prettier": "^3.2.0",
    "socket.io-client": "^4.8.3",
    "supertest": "^7.1.0",
    "ts-jest": "^29.0.0",
    "ts-node": "^10.9.2",
    "tsc-alias": "^1.8.16",
    "tsx": "^4.19.3",
    "typescript": "^5.3.0",
    "yaml": "^1.10.3"
  }
}
